{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist/client" } },
    { "src": "api/ssr.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "\\/(.*\\.(?:js|css|png|jpg|jpeg|svg|ico|webp|map))$",
      "dest": "\\/$1"
    },
    {
      "src": "\\/(.*)",
      "dest": "\/api\/ssr.js"
    }
  ]
}
